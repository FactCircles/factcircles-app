{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "store",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "john@factcircles.com",
        "ascAppId": "6759204640",
        "appleTeamId": "8S5M6FGH6U"
      }
    },
    "production": {
      "ios": {
        "appleId": "john@factcircles.com",
        "ascAppId": "6759204640",
        "appleTeamId": "8S5M6FGH6U",
        "metadataPath": "./store-metadata/ios"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
