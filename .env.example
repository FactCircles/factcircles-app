# FactCircles Environment Variables — EXAMPLE FILE
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Grok AI (xAI) — get your key at https://console.x.ai
EXPO_PUBLIC_GROK_API_KEY=xai-your-key-here
EXPO_PUBLIC_GROK_API_URL=https://api.x.ai/v1

# Depolarization Dojo
EXPO_PUBLIC_DOJO_API_KEY=your-dojo-key-here

# Stripe — get your keys at https://dashboard.stripe.com
# Use pk_test_... for development, pk_live_... for production
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
# NEVER put your secret key (sk_...) here — use a backend server
EXPO_PUBLIC_STRIPE_SECRET_KEY=DO_NOT_PUT_SECRET_KEY_HERE

# Apple Pay
EXPO_PUBLIC_APPLE_PAY_MERCHANT_ID=merchant.com.factcircles.app

# Session Pricing
EXPO_PUBLIC_SESSION_PRICE_CENTS=3000
EXPO_PUBLIC_SESSION_DURATION_MINUTES=55

# App Config
EXPO_PUBLIC_APP_NAME=FactCircles
EXPO_PUBLIC_SUPPORT_EMAIL=support@factcircles.com
